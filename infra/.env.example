# Copy to infra/.env on the VPS and fill in real values. Used by docker-compose.

# Base domain (Caddyfile uses webrankingreports.com and pb.webrankingreports.com)
# WEBRANKINGREPORTS_DOMAIN=webrankingreports.com
# POCKETBASE_SUBDOMAIN=pb

# Nuxt must call PocketBase at the public URL (browser)
NUXT_PUBLIC_POCKETBASE_URL=https://pb.webrankingreports.com
APP_URL=https://webrankingreports.com

# Server-only: PocketBase admin (same login as https://pb.webrankingreports.com/_/)
# Use http://pb:8090 when running in Docker so the web container reaches PB on the internal network.
PB_URL=http://pb:8090
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=

# Required for Google OAuth. Generate with: openssl rand -hex 32
STATE_SIGNING_SECRET=
# Optional; team-invite password links default to STATE_SIGNING_SECRET
# INVITE_PASSWORD_TOKEN_SECRET=

# Comma-separated emails that can access Admin → Integrations (e.g. admin@vma.agency)
ADMIN_EMAILS=admin@vma.agency

# Required for team/client invites and other mail from the Nuxt app. PocketBase’s Admin API hides
# the mailer password (******), so the web container cannot reuse PB settings without these.
# Use the same mailbox user + password as PocketBase → Settings → Mailer.
SMTP_USER=
SMTP_PASSWORD=
# Optional: force host/port from env (recommended on some VPS setups)
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_SECURE=false

# Optional: PageSpeed Insights API key for Lighthouse (recommended for production quota)
# PAGESPEED_API_KEY=

# Set to false to hide WooCommerce integration and reports everywhere (default: true)
# NUXT_PUBLIC_WOOCOMMERCE_ENABLED=false

# Automated rank tracking (Nuxt server): refresh all sites’ keywords on a schedule.
# docker-compose defaults: enabled, America/Chicago, Friday 00:00. Set to false to disable.
# RANK_TRACKING_WEEKLY_CRON_ENABLED=true
# RANK_TRACKING_CRON_TZ=America/Chicago
# RANK_TRACKING_CRON_EXPRESSION=0 0 * * 5
