# Web Ranking Reports — Caddy reverse proxy
# Env (set in docker-compose): WEBRANKINGREPORTS_DOMAIN, POCKETBASE_SUBDOMAIN
# - Apex https://WEBRANKINGREPORTS_DOMAIN → Nuxt (marketing homepage at /, app routes under /dashboard, etc.)
# - www → permanent redirect to apex
# - https://POCKETBASE_SUBDOMAIN.WEBRANKINGREPORTS_DOMAIN → PocketBase

{
  email admin@webrankingreports.com
}

# Optional: test by IP when DNS is not working yet (remove this block after DNS is live)
:80 {
  reverse_proxy web:3000 {
    transport http {
      versions 1.1
    }
  }
}

# Nuxt app — apex (top-level) domain = public homepage + authenticated app
{$WEBRANKINGREPORTS_DOMAIN:webrankingreports.com} {
  reverse_proxy web:3000 {
    transport http {
      versions 1.1
    }
  }
}

# Send www traffic to apex so the homepage and app live on one canonical host
www.{$WEBRANKINGREPORTS_DOMAIN:webrankingreports.com} {
  redir https://{$WEBRANKINGREPORTS_DOMAIN:webrankingreports.com}{uri} permanent
}

# PocketBase API + Admin
{$POCKETBASE_SUBDOMAIN:pb}.{$WEBRANKINGREPORTS_DOMAIN:webrankingreports.com} {
  reverse_proxy pb:8090 {
    transport http {
      versions 1.1
    }
  }
}
