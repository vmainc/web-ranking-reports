# Copy to .env for local development.
# PocketBase must be reachable at this URL from the browser (e.g. same machine or tunnel).

NUXT_PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090
APP_URL=http://localhost:3000

# Server-only (for Google OAuth and admin). Not sent to the client.
PB_URL=http://127.0.0.1:8090
# Use PB_ADMIN_* or POCKETBASE_ADMIN_* (PocketBase admin UI login, not app users)
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=
STATE_SIGNING_SECRET=change-me-to-a-long-random-string
ADMIN_EMAILS=you@example.com

# --- Transactional email (team + client invites, sent by Nuxt, not PocketBase) ---
# PocketBase’s Admin API hides the SMTP password (******), so invites fail unless you set the
# same mailbox here. Copy host/port/username/password from PocketBase → Settings → Mailer.
# SMTP_USER=you@yourdomain.com
# SMTP_PASSWORD=your-mailbox-password-or-app-password
# Optional on VPS: force relay from env only (avoids PB API quirks)
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_SECURE=false

# Optional: PageSpeed Insights API key for Lighthouse (recommended for production quota)
# PAGESPEED_API_KEY=

# Optional: weekly SERP refresh in the Nuxt server (same vars as infra/.env in Docker)
# RANK_TRACKING_WEEKLY_CRON_ENABLED=true
# RANK_TRACKING_CRON_TZ=America/Chicago
# RANK_TRACKING_CRON_EXPRESSION=0 0 * * 5
